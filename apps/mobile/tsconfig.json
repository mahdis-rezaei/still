{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@workspace/api-client-react": [
        "../../lib/api-client-react/src/index.ts"
      ],
      "@workspace/api-zod": ["../../lib/api-zod/src/index.ts"]
    }
  },
  "include": [
