{
  "expo": {
    "name": "Yadegar",
    "slug": "yadegar",
    "scheme": "yadegar",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F1E6"
    },
    "ios": {
      "bundleIdentifier": "com.yadegar.app",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yadegar.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F1EAD7"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Yadegar to use Face ID to keep your journal private."
        }
      ],
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Yadegar to add photos to your pages.",
          "cameraPermission": "Allow Yadegar to take a photo for your page."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Yadegar to use the microphone to dictate your writing.",
          "speechRecognitionPermission": "Allow Yadegar to transcribe your speech into text."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "713e75e4-8c5c-46cf-9b40-de16938bea8a"
      }
    },
    "owner": "mahdis-rezaei"
  }
}
